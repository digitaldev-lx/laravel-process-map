{
    "name": "digitaldev-lx/laravel-process-map",
    "description": "Static-analysis package that maps the business processes inside any Laravel application: models, controllers, actions, jobs, events, listeners, notifications, policies, commands, routes, schedule, and broadcasting.",
    "keywords": [
        "laravel",
        "process-map",
        "static-analysis",
        "ast",
        "documentation",
        "consulting",
        "automation",
        "mcp",
        "claude-code",
        "ai-tooling",
        "digitaldev"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "DigitalDev",
            "email": "geral@digitaldev.pt",
            "role": "Development Team"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0 || ^13.0",
        "laravel/mcp": "^0.7",
        "nikic/php-parser": "^5.0",
        "symfony/finder": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "larastan/larastan": "^3.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "DigitaldevLx\\LaravelProcessMap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DigitaldevLx\\LaravelProcessMap\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage --min=80",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "DigitaldevLx\\LaravelProcessMap\\Providers\\ProcessMapServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
